# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vehicle_erp

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# 2Factor SMS
TWO_FACTOR_API_KEY=

# ── NIC E-Invoice (IRP) ─────────────────
# Set EINVOICE_ENV to 'production' when live, defaults to 'sandbox'
EINVOICE_ENV=sandbox
# Get credentials from https://einv-apisandbox.nic.in (sandbox) or https://einvoice1.gst.gov.in (prod)
EINVOICE_CLIENT_ID=
EINVOICE_CLIENT_SECRET=
EINVOICE_USERNAME=
EINVOICE_PASSWORD=
EINVOICE_GSTIN=
# Production only: paste the NIC production RSA public key here (base64, single line)
# EINVOICE_PUBLIC_KEY=
