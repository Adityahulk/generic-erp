# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vehicle_erp

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# WhatsApp (invoice/quotation/loan messages & share links)
# mock | twilio | waba (waba not implemented)
WHATSAPP_PROVIDER=mock
# Optional: separate secret for JWT share links (defaults to JWT_SECRET)
# SHARE_SECRET=
# Public URL used in WhatsApp share links (defaults to CORS_ORIGIN)
# PUBLIC_APP_URL=http://localhost:5173

# Twilio WhatsApp (when WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 or whatsapp:+... — also accepts TWILIO_WHATSAPP_NUMBER
TWILIO_WHATSAPP_FROM=

# 2Factor SMS
TWO_FACTOR_API_KEY=

# ── Masters India E-Invoice (IRN) & E-Way Bill ─────────────────
# sandbox | production — API host: sandb-api.mastersindia.co vs router.mastersindia.co
MASTERS_INDIA_ENV=sandbox
# API key from Masters UI — header api_key only (Masters docs). If you get "access token was not found", try MASTERS_INDIA_OPAQUE_AUTH=bearer_and_api_key or add USERNAME/PASSWORD.
MASTERS_INDIA_API_KEY=
MASTERS_INDIA_USERNAME=
MASTERS_INDIA_PASSWORD=
# MASTERS_INDIA_OPAQUE_AUTH=api_key_only
# MASTERS_INDIA_API_AUTH_MODE=authorization_jwt
